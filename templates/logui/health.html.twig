{% extends '@LogUi/logui/layout.html.twig' %}

{% block content %}
{% set h = health %}
{% set hasAny = h.model or h.uptime or h.temperature or h.throttle or h.load or h.memory is not empty or h.disks is not empty or h.interfaces is not empty or h.docker is not empty or h.services is not empty or h.processes is not empty or h.network_usage %}

{% if not hasAny %}
    <p class="ctx">No server health data available on this host.</p>
{% else %}

<div class="cards">
    {% if h.model %}
    <div class="card"><h4>Host</h4><div class="big">{{ h.model }}</div></div>
    {% endif %}

    {% if h.uptime %}
    <div class="card"><h4>Uptime</h4><div class="big">{{ h.uptime.human }}</div></div>
    {% endif %}

    {% if h.temperature %}
    <div class="card"><h4>Temperature</h4><div class="big hl-{{ h.temperature.color }}">{{ h.temperature.label }}</div></div>
    {% endif %}

    {% if h.load %}
    <div class="card">
        <h4>Load (1 / 5 / 15 min)</h4>
        <div class="big hl-{{ h.load.color }}">{{ h.load['1m'] }} <span class="ctx" style="font-size:13px">/ {{ h.load['5m'] }} / {{ h.load['15m'] }}</span></div>
        <div class="ctx" style="font-size:12px">{{ h.load.cpu_count }} CPU</div>
        <div class="bar"><span class="hl-{{ h.load.color }}" style="width:{{ h.load.pct_1m }}%"></span></div>
    </div>
    {% endif %}

    {% if h.memory is not empty %}
    <div class="card">
        <h4>Memory</h4>
        <div class="big hl-{{ h.memory.color }}">{{ h.memory.used_pct }}%</div>
        <div class="ctx" style="font-size:12px">{{ h.memory.used }} / {{ h.memory.total }} · cache {{ h.memory.cached }}</div>
        <div class="bar"><span class="hl-{{ h.memory.color }}" style="width:{{ h.memory.used_pct }}%"></span></div>
    </div>
    {% endif %}

    {% if h.disk_usage %}
    <div class="card">
        <h4>Disk</h4>
        <div class="big hl-{{ h.disk_usage.color }}">{{ h.disk_usage.used_pct }}%</div>
        <div class="ctx" style="font-size:12px">{{ h.disk_usage.used }} / {{ h.disk_usage.size }}</div>
        <div class="bar"><span class="hl-{{ h.disk_usage.color }}" style="width:{{ h.disk_usage.used_pct }}%"></span></div>
    </div>
    {% endif %}
</div>

{% if h.throttle %}
<div class="section">
    <h3>Power / Throttling</h3>
    {% if h.throttle.ok %}
        <p class="hl-success">OK — no throttling reported.</p>
    {% else %}
        <p class="hl-danger">{{ h.throttle.issues|join(', ') }}</p>
    {% endif %}
</div>
{% endif %}

{% if h.disks is not empty %}
<div class="section">
    <h3>Disks</h3>
    <table>
        <thead><tr><th>Mount</th><th>Source</th><th>FS</th><th class="num">Used</th><th class="num">Size</th><th>Usage</th></tr></thead>
        <tbody>
        {% for d in h.disks %}
            <tr>
                <td>{{ d.mount }}</td>
                <td class="ctx">{{ d.source }}</td>
                <td class="ctx">{{ d.fstype }}</td>
                <td class="num">{{ d.used }}</td>
                <td class="num">{{ d.size }}</td>
                <td>
                    <span class="hl-{{ d.color }}">{{ d.used_pct }}%</span>
                    <div class="bar"><span class="hl-{{ d.color }}" style="width:{{ d.used_pct }}%"></span></div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if h.processes is not empty %}
<div class="section">
    <h3>Top processes</h3>
    <table>
        <thead><tr><th class="num">PID</th><th>User</th><th class="num">%CPU</th><th class="num">%MEM</th><th class="num">RSS</th><th>Command</th></tr></thead>
        <tbody>
        {% for p in h.processes %}
            <tr>
                <td class="num ctx">{{ p.pid }}</td>
                <td class="ctx">{{ p.user }}</td>
                <td class="num"><span class="hl-{{ p.color }}">{{ p.cpu }}</span></td>
                <td class="num">{{ p.mem }}</td>
                <td class="num">{{ p.rss }}</td>
                <td>{{ p.command }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if h.interfaces is not empty %}
<div class="section">
    <h3>Network interfaces</h3>
    <table>
        <thead><tr><th>Interface</th><th>State</th><th>Addresses</th><th>MAC</th></tr></thead>
        <tbody>
        {% for i in h.interfaces %}
            <tr>
                <td>{{ i.name }}</td>
                <td><span class="badge hl-{{ i.color }}">{{ i.state }}</span></td>
                <td class="ctx">{{ i.ips|join(', ') ?: '—' }}</td>
                <td class="ctx">{{ i.mac }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if h.network_usage %}
<div class="section">
    <h3>Network usage (vnstat{{ h.network_usage.version ? ' ' ~ h.network_usage.version }})</h3>
    <table>
        <thead><tr><th>Interface</th><th class="num">↓ rx</th><th class="num">↑ tx</th><th class="num">Total</th><th>This month (→ est.)</th></tr></thead>
        <tbody>
        {% for i in h.network_usage.interfaces %}
            <tr>
                <td>{{ i.name }}</td>
                <td class="num">{{ i.rx_fmt }}</td>
                <td class="num">{{ i.tx_fmt }}</td>
                <td class="num">{{ i.total_fmt }}</td>
                <td>{% if i.month %}{{ i.month.total_fmt }} → ~{{ i.month.est_total_fmt }} <span class="ctx">({{ i.month.progress_pct }}% of month)</span>{% else %}<span class="ctx">—</span>{% endif %}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if h.docker is not empty %}
<div class="section">
    <h3>Docker</h3>
    <table>
        <thead><tr><th>Container</th><th>Image</th><th>Status</th><th class="num">CPU</th><th>Memory</th></tr></thead>
        <tbody>
        {% for c in h.docker %}
            <tr>
                <td>{{ c.name }}</td>
                <td class="ctx">{{ c.image }}</td>
                <td><span class="badge hl-{{ c.running ? 'success' : 'secondary' }}">{{ c.status }}</span></td>
                <td class="num">{{ c.cpu ?: '—' }}</td>
                <td class="ctx">{{ c.mem ?: '—' }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if h.services is not empty %}
<div class="section">
    <h3>Services</h3>
    <p>
        {% for s in h.services %}
            <span class="badge hl-{{ s.color }}">{{ s.name }}: {{ s.state }}</span>
        {% endfor %}
    </p>
</div>
{% endif %}

{% endif %}
{% endblock %}
