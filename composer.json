{
    "name": "aleblanc/logui",
    "description": "Log viewer & lightweight profiler for Symfony & Laravel. File-based, zero-infra.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["monolog", "log", "log-viewer", "profiler", "symfony", "laravel", "debug"],
    "require": {
        "php": ">=8.2",
        "monolog/monolog": "^3.0",
        "symfony/config": "^6.4|^7.0|^8.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/event-dispatcher": "^6.4|^7.0|^8.0",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "symfony/http-kernel": "^6.4|^7.0|^8.0",
        "symfony/routing": "^6.4|^7.0|^8.0",
        "symfony/twig-bundle": "^6.4|^7.0|^8.0"
    },
    "suggest": {
        "doctrine/dbal": "Enables automatic SQL query counting + slow-query detection per request/command (^3.7|^4.0)."
    },
    "require-dev": {
        "doctrine/dbal": "^3.7|^4.0",
        "friendsofphp/php-cs-fixer": "^3.50",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^6.4|^7.0|^8.0",
        "symfony/css-selector": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/monolog-bundle": "^3.10"
    },
    "autoload": {
        "psr-4": { "Aleblanc\\LogUi\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Aleblanc\\LogUi\\Tests\\": "tests/",
            "Aleblanc\\LogUi\\PhpStan\\": "phpstan-rules/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --diff"
    },
    "config": { "sort-packages": true },
    "minimum-stability": "stable",
    "prefer-stable": true
}
